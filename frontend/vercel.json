{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://freddy-jmdataai-nexus-crm-backend.hf.space/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Credentials", "value": "true" }
      ]
    }
  ]
}
